#!/bin/zsh
################################################################################
# Google Cloud SDK configuration (macOS/Darwin specific)
# Adds gcloud to PATH and loads completion if installed
################################################################################

# Add homebrew gcloud to PATH if installed
if [ -d /opt/homebrew/share/google-cloud-sdk ]; then
  addpath /opt/homebrew/share/google-cloud-sdk/bin
elif [ -d /usr/local/google-cloud-sdk ]; then
  addpath /usr/local/google-cloud-sdk/bin
fi

# Load gcloud completion (bash-style, sourced via bashcompinit)
local gcloud_completion="/opt/homebrew/share/google-cloud-sdk/completion.zsh.inc"
[[ -f "$gcloud_completion" ]] && source "$gcloud_completion"
