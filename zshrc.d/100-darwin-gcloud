#!/bin/zsh
################################################################################
# Google Cloud SDK configuration (macOS/Darwin specific)
# Adds gcloud to PATH and loads completion if installed
################################################################################

# Add homebrew gcloud to PATH if installed
if [ -d /opt/homebrew/share/google-cloud-sdk ]; then
  addpath /opt/homebrew/share/google-cloud-sdk/bin
elif [ -d /usr/local/google-cloud-sdk ]; then
  addpath /usr/local/google-cloud-sdk/bin
fi

# Load gcloud completion (uses bash completion style)
if command -v gcloud &>/dev/null || [[ -n "${TMP_PATH}" ]] && PATH="${TMP_PATH}:${PATH}" command -v gcloud &>/dev/null; then
  # gcloud uses bash-style completion, so we need to source it directly
  local gcloud_completion_source="/opt/homebrew/share/zsh/site-functions/_google_cloud_sdk"
  if [[ -f "$gcloud_completion_source" ]]; then
    source "$gcloud_completion_source"
  elif [[ -f "${HOME}/.zsh/completions/_gcloud" ]]; then
    source "${HOME}/.zsh/completions/_gcloud"
  fi
fi
