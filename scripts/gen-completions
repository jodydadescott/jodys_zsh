#!/usr/bin/env zsh
setopt no_xtrace

# Scan binaries for completion support and generate zsh completions

COMPLETIONS_DIR="${HOME}/.zsh/completions"
SCAN_DIRS=(
  /opt/homebrew/bin
  "${HOME}/.cargo/bin"
  "${HOME}/.local/bin"
  "${GOROOT:-${HOME}/.local/go/root}/bin"
  "${GOPATH:-${HOME}/.local/go/path}/bin"
  /opt/homebrew/share/google-cloud-sdk/bin
)
TIMEOUT=3

# Binaries to skip (false positives or no stdout completions)
typeset -A SKIP_BINS=(
  [autopoint]=1
  [cargo]=1
  [claude]=1
  [copilot]=1
  [eksctl-anywhere]=1
  [fzf]=1
  [gettext.sh]=1
  [gettextize]=1
  [glibtool]=1
  [glibtoolize]=1
  [lto-dump-14]=1
  [node]=1
  [rename]=1
  [cargo-clippy]=1
  [cargo-fmt]=1
  [cargo-miri]=1
  [clippy-driver]=1
  [rls]=1
  [rust-analyzer]=1
  [rust-gdb]=1
  [rust-gdbgui]=1
  [rust-lldb]=1
  [rustc]=1
  [rustdoc]=1
  [rustfmt]=1
  [shellcheck]=1
  [shfmt]=1
  [terraform]=1
  [zoxide]=1
)

# Strategies to try, ordered by popularity
strategies=(
  "completion zsh"
  "completion -s zsh"
  "completions zsh"
  "--completion zsh"
  "--completions zsh"
  "--gen-completions zsh"
  "--zsh"
  "complete --shell zsh"
  "generate-shell-completion zsh"
)

usage() {
  cat <<'EOF'
Usage: gen-completions [OPTIONS] [--dir PATH ...]

Scans binaries for zsh completion support and generates completion files.

Options:
  --dir PATH     Add an extra directory to scan (can be repeated)
  --dry-run      Only check and log, don't write completion files
  -v, --verbose  Log all binaries, not just updates and failures
  -h, --help     Show this help
EOF
}

# Returns: 0=fresh (skipped), 1=failed, 2=updated
try_completion() {
  setopt local_options no_xtrace
  local bin="$1"
  local name="$2"
  local dest="$COMPLETIONS_DIR/_$name"
  local output

  # Skip if completion file exists, is newer than the binary, and has our marker
  if [[ -f "$dest" ]] && [[ "$dest" -nt "$bin" ]] && head -1 "$dest" | grep -q "^# generated by gen-completions$"; then
    [[ $verbose -eq 1 ]] && echo "$name : completion=true : status=fresh"
    return 0
  fi

  for s in "${strategies[@]}"; do
    output=$(timeout "$TIMEOUT" "$bin" ${=s} </dev/null 2>/dev/null)
    if [[ $? -eq 0 ]] && [[ -n "$output" ]] && [[ "$output" == *"#compdef"* || "$output" == *"compdef "* || "$output" == *"_arguments"* || "$output" == *"compadd"* || "$output" == *"###-begin-"* ]]; then
      if [[ $dry_run -eq 0 ]]; then
        { echo "# generated by gen-completions"; echo "$output"; } > "$dest"
      fi
      echo "$name : completion=true : status=updated : format=\"$s\""
      return 2
    fi
  done
  return 1
}

typeset -a extra_dirs=()
dry_run=0
verbose=0
while [[ $# -gt 0 ]]; do
  case "$1" in
    --dir)        shift; extra_dirs+=("$1") ;;
    --dry-run)    dry_run=1 ;;
    -v|--verbose) verbose=1 ;;
    -h|--help)    usage; exit 0 ;;
    *)            echo "Unknown option: $1" >&2; usage >&2; exit 1 ;;
  esac
  shift
done
SCAN_DIRS+=("${extra_dirs[@]}")

mkdir -p "$COMPLETIONS_DIR"

found=0
updated=0
checked=0
cleaned=0

# Scan and generate completions
for dir in "${SCAN_DIRS[@]}"; do
  [[ -d "$dir" ]] || continue
  for bin in "$dir"/*; do
    [[ -x "$bin" ]] && [[ -f "$bin" ]] || continue
    name="${bin:t}"
    [[ "$name" == *.* ]] && [[ "$name" != *.sh ]] && continue
    [[ "$name" == _* ]] && continue
    [[ -n "${SKIP_BINS[$name]}" ]] && continue
    ((checked++))

    # Pre-filter with strings
    if ! strings "$bin" 2>/dev/null | grep -qi "zsh"; then
      [[ $verbose -eq 1 ]] && echo "$name : completion=false"
      continue
    fi

    try_completion "$bin" "$name"
    case $? in
      0) ((found++)) ;;          # fresh
      2) ((found++)); ((updated++)) ;;  # updated
      *) echo "$name : completion=true : status=failed" ;;
    esac
  done
done

# Cleanup stale completions (only files we generated)
for comp_file in "$COMPLETIONS_DIR"/_*; do
  [[ -f "$comp_file" ]] || continue
  head -1 "$comp_file" | grep -q "^# generated by gen-completions$" || continue
  local bin_name="${${comp_file:t}#_}"
  if ! command -v "$bin_name" >/dev/null 2>&1; then
    echo "$bin_name : status=removed (binary not found)"
    if [[ $dry_run -eq 0 ]]; then
      rm -f "$comp_file"
    fi
    ((cleaned++))
  fi
done

# Invalidate zcompdump if anything changed
if [[ $dry_run -eq 0 ]] && (( updated + cleaned > 0 )); then
  rm -f ~/.zcompdump* ~/.cache/zsh/compdump* 2>/dev/null
fi

echo ""
echo "checked=$checked found=$found cleaned=$cleaned"
